# ── Neon Database ──────────────────────────────────────────────────────
# Get from: https://neon.tech → Your Project → Connection Details
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# ── Clerk Authentication ────────────────────────────────────────────────
# Get from: https://clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (do not change unless you rename pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Get from: Clerk Dashboard → Webhooks → (your endpoint) → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ── AI Providers (at least one required) ─────────────────────────────────
# The app uses automatic fallback: Claude → Gemini → NVIDIA
# Set at least one API key to enable AI features

# Claude (Anthropic) - Primary/Recommended
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini - Secondary fallback
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza...

# NVIDIA NIM - Tertiary fallback
# Get from: https://build.nvidia.com → Get API Key
NVIDIA_API_KEY=nvapi-...

# ── Supabase Storage ────────────────────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App Configuration ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SkillLover

# ── Credits & Pricing ───────────────────────────────────────────────────
CREDITS_PER_PURCHASE=4
CREDIT_PRICE_INR=20
FREE_CREDITS=2
